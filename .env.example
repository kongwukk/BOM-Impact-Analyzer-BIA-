# Backend settings use the BIA_ prefix.
BIA_ENVIRONMENT=development
BIA_DATABASE_URL=sqlite:///./data/bom.db
BIA_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
BIA_UPLOAD_MAX_MB=20
BIA_UPLOAD_DIR=./data/uploads

# OpenAI-compatible LLM (OpenAI / DeepSeek / Qwen / local compatible gateway).
# Queries still work in local rule mode when disabled or unavailable.
BIA_LLM_ENABLED=false
BIA_LLM_API_KEY=
BIA_LLM_BASE_URL=https://api.openai.com/v1
BIA_LLM_MODEL=gpt-4o-mini
BIA_LLM_TIMEOUT_SECONDS=30

# Set only when the frontend API is hosted on another origin.
VITE_API_BASE_URL=
